{
  "name": "@pakhad/default",
  "version": "1.0.0",
  "description": "Zero-config pakhad — pre-configured detector with English + Indian locales. Just import and use.",
  "repository": {
    "type": "git",
    "url": "https://github.com/nikhilchintawar/pakhad.git",
    "directory": "packages/default"
  },
  "homepage": "https://github.com/nikhilchintawar/pakhad#readme",
  "bugs": {
    "url": "https://github.com/nikhilchintawar/pakhad/issues"
  },
  "keywords": ["pakhad", "gibberish-detection", "fake-input", "validation", "zero-config", "fintech", "kyc"],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@pakhad/core": "workspace:^",
    "@pakhad/locale-en": "workspace:^",
    "@pakhad/locale-in": "workspace:^"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
