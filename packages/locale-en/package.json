{
  "name": "@pakhad/locale-en",
  "version": "0.1.2",
  "description": "English locale pack for pakhad — Markov model and name list",
  "repository": {
    "type": "git",
    "url": "https://github.com/nikhilchintawar/pakhad.git",
    "directory": "packages/locale-en"
  },
  "homepage": "https://github.com/nikhilchintawar/pakhad#readme",
  "bugs": {
    "url": "https://github.com/nikhilchintawar/pakhad/issues"
  },
  "keywords": ["pakhad", "gibberish-detection", "english", "locale", "names"],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "models"],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@pakhad/train": "workspace:^"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
